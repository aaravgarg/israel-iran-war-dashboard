# OpenAI (required for AI summaries + incident extraction)
OPENAI_API_KEY=sk-...

# Bing News Search (optional, falls back to GDELT if not set)
BING_NEWS_API_KEY=
BING_NEWS_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search

# Pipeline settings
POLL_INTERVAL_MS=600000
SUMMARY_CACHE_TTL_MS=1800000
GDELT_TIMESPAN=7d
GDELT_MAX_RECORDS=250
